{
  "name": "solidgate-ai-shopping-assistant",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --import tsx scripts/migrate.ts",
    "db:reset": "node --import tsx scripts/reset-db.ts",
    "db:seed": "node --import tsx scripts/seed-db.ts",
    "verify": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.10",
    "openai": "^6.46.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
